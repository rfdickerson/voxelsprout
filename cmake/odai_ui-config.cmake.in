@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(nlohmann_json CONFIG REQUIRED)

# odai_ui_vulkan (the Vulkan bridge) is only exported when the app was
# configured with a Vulkan render backend; skip its dependencies otherwise so
# a headless consumer of odai_ui alone doesn't need a Vulkan SDK installed.
set(ODAI_UI_HAS_VULKAN @ODAI_UI_HAS_VULKAN@)
if(ODAI_UI_HAS_VULKAN)
    find_dependency(Vulkan)
    find_dependency(VulkanMemoryAllocator CONFIG)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/odai_ui-targets.cmake")

check_required_components(odai_ui)
